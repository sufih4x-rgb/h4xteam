<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel | Withdrawal Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #4361ee; --bg: #0f172a; --card: #1e293b; --white: #ffffff; --success: #10b981; --danger: #ef4444; --warning: #f59e0b; }
        body { background: var(--bg); font-family: 'Plus Jakarta Sans', sans-serif; color: var(--white); margin: 0; padding: 20px; }
        .admin-container { max-width: 900px; margin: 0 auto; }
        
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 1px solid #334155; padding-bottom: 20px; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px; }
        .stat-card { background: var(--card); padding: 20px; border-radius: 18px; border: 1px solid #334155; }
        .stat-card small { color: #94a3b8; font-size: 12px; font-weight: 600; }
        .stat-card h2 { margin: 5px 0 0; font-size: 24px; }

        .request-card { background: var(--card); border-radius: 20px; padding: 20px; margin-bottom: 15px; border: 1px solid #334155; display: flex; justify-content: space-between; align-items: center; transition: 0.3s; }
        .request-card:hover { border-color: var(--primary); transform: translateY(-2px); }
        
        .user-info b { font-size: 16px; color: var(--white); display: block; }
        .user-info span { font-size: 13px; color: #94a3b8; }
        .amount-tag { font-size: 20px; font-weight: 800; color: var(--success); margin: 5px 0; }
        .upi-box { background: #0f172a; padding: 5px 12px; border-radius: 8px; font-family: monospace; font-size: 12px; color: var(--primary); border: 1px solid #334155; }

        .actions { display: flex; gap: 10px; }
        button { padding: 10px 18px; border-radius: 12px; border: none; font-weight: 700; cursor: pointer; transition: 0.2s; font-size: 13px; }
        .btn-approve { background: var(--success); color: white; }
        .btn-reject { background: var(--danger); color: white; }
        button:hover { opacity: 0.8; transform: scale(1.05); }

        /* Modal Style */
        #rejectModal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:100; align-items:center; justify-content:center; }
        .modal-content { background: var(--card); padding: 30px; border-radius: 25px; width: 90%; max-width: 400px; border: 1px solid #334155; }
        textarea { width: 100%; background: #0f172a; border: 1px solid #334155; border-radius: 12px; padding: 15px; color: white; margin: 15px 0; box-sizing: border-box; }
        
        .badge { font-size: 10px; padding: 4px 8px; border-radius: 6px; font-weight: 800; text-transform: uppercase; }
        .badge-pending { background: var(--warning); color: #000; }
    </style>
</head>
<body>

<div class="admin-container">
    <div class="header">
        <div>
            <h1 style="margin:0;">Withdrawal Admin</h1>
            <p style="color:#94a3b8; margin:5px 0 0;">Manage user cashout requests</p>
        </div>
        <div id="loading" style="color: var(--primary);">Updating...</div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <small>PENDING REQUESTS</small>
            <h2 id="countPending">0</h2>
        </div>
        <div class="stat-card">
            <small>TOTAL DISBURSED</small>
            <h2 id="totalPaid" style="color: var(--success);">₹0</h2>
        </div>
    </div>

    <h3 style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
        Active Requests <span id="liveBadge" class="badge badge-pending">Live</span>
    </h3>

    <div id="adminList">
        <p style="text-align:center; color:#64748b; padding:40px;">No pending requests found.</p>
    </div>
</div>

<div id="rejectModal">
    <div class="modal-content">
        <h3 style="margin-top:0;">Reject Withdrawal</h3>
        <p style="font-size:13px; color:#94a3b8;">Enter the reason why you are canceling this request. This will be shown to the user.</p>
        <textarea id="rejectReason" rows="4" placeholder="Example: Incorrect UPI ID, Multiple accounts, etc."></textarea>
        <div style="display:flex; gap:10px;">
            <button class="btn-reject" style="flex:1" onclick="confirmReject()">SUBMIT REJECTION</button>
            <button style="flex:1; background:#475569; color:white;" onclick="closeModal()">CANCEL</button>
        </div>
    </div>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
    import { getDatabase, ref, onValue, update, remove } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

    const firebaseConfig = {
        apiKey: "AIzaSyAzfvbiqRqsQwBOOIkegxJD09di-S_tfHg",
        authDomain: "test-eb5e7.firebaseapp.com",
        databaseURL: "https://test-eb5e7-default-rtdb.firebaseio.com",
        projectId: "test-eb5e7",
        appId: "1:366282855653:web:dca7e000f5a22fb11f300c"
    };

    const app = initializeApp(firebaseConfig);
    const db = getDatabase(app);

    let currentRejectId = "";

    // Load Live Requests
    onValue(ref(db, "withdrawals"), snap => {
        const list = document.getElementById("adminList");
        let html = "";
        let pendingCount = 0;
        let totalPaid = 0;

        if (snap.exists()) {
            snap.forEach(child => {
                const data = child.val();
                const id = child.key;

                if (data.status === "Approved") {
                    totalPaid += Number(data.amount);
                }

                if (data.status === "Pending") {
                    pendingCount++;
                    html += `
                    <div class="request-card">
                        <div class="user-info">
                            <span>${new Date(data.timestamp).toLocaleString()}</span>
                            <b>${data.displayName || 'Unknown User'}</b>
                            <small style="color:#94a3b8">${data.email}</small>
                            <div class="amount-tag">₹${data.amount}</div>
                            <div class="upi-box">${data.upiId}</div>
                        </div>
                        <div class="actions">
                            <button class="btn-approve" onclick="actionApprove('${id}')">APPROVE</button>
                            <button class="btn-reject" onclick="openRejectModal('${id}')">REJECT</button>
                        </div>
                    </div>`;
                }
            });
            list.innerHTML = html || `<p style="text-align:center; color:#64748b; padding:40px;">No pending requests found.</p>`;
            document.getElementById("countPending").innerText = pendingCount;
            document.getElementById("totalPaid").innerText = "₹" + totalPaid;
            document.getElementById("loading").innerText = "Idle";
        }
    });

    window.actionApprove = async (id) => {
        if(!confirm("Are you sure you want to approve this withdrawal?")) return;
        document.getElementById("loading").innerText = "Processing...";
        await update(ref(db, `withdrawals/${id}`), {
            status: "Approved",
            userNotified: false // This triggers the popup on user's page
        });
        alert("Withdrawal Approved Successfully!");
    };

    window.openRejectModal = (id) => {
        currentRejectId = id;
        document.getElementById("rejectModal").style.display = "flex";
    };

    window.closeModal = () => {
        document.getElementById("rejectModal").style.display = "none";
    };

    window.confirmReject = async () => {
        const reason = document.getElementById("rejectReason").value.trim();
        if(!reason) return alert("Please enter a reason for rejection!");

        document.getElementById("loading").innerText = "Rejecting...";
        
        // Find user UID and Amount first to refund balance
        onValue(ref(db, `withdrawals/${currentRejectId}`), async (snap) => {
            const data = snap.val();
            if(data && data.status === "Pending") {
                // 1. Update withdrawal status and add reason
                await update(ref(db, `withdrawals/${currentRejectId}`), {
                    status: "Rejected",
                    reason: reason,
                    userNotified: false
                });

                // 2. Refund balance to user
                await update(ref(db, `users/${data.uid}`), {
                    balance: (data.amount + (data.userBalance || 0)) // Note: Using Firebase increment is better but this works if userBal is tracked
                });
                
                // OR better, since you used increment(-amt) in withdraw page:
                // await update(ref(db, `users/${data.uid}`), { balance: increment(data.amount) }); 
                // (Note: To use increment here, you need to import it)

                closeModal();
                alert("Withdrawal rejected and user notified!");
            }
        }, { onlyOnce: true });
    };
</script>
</body>
</html>
